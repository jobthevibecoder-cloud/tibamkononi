# Tiba Mkononi - Environment Variables
# Copy this to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://tiba_user:tiba_password@localhost:5432/tiba_mkononi
DATABASE_URL_SYNC=postgresql://tiba_user:tiba_password@localhost:5432/tiba_mkononi

# Redis
REDIS_URL=redis://localhost:6379/0

# Hugging Face (for Gemma 4)
HF_TOKEN=hf_your_token_here
GEMMA_MODEL=google/gemma-4-2b-it

# Security
SECRET_KEY=change-this-to-a-random-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# File Storage (MinIO / S3-compatible)
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=tiba-mkononi-uploads
STORAGE_SECURE=False

# App
APP_NAME=Tiba Mkononi
DEBUG=True
ENVIRONMENT=development
API_V1_PREFIX=/v1

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://tibamkononi.vercel.app"]
